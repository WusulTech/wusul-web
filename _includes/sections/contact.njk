    <section class="ws-contact">
      <div class="container">
        <!-- Header -->
        <div class="ws-contact__header text-center">
          <h2 class="ws-contact__title">Get in Touch</h2>
          <p class="ws-contact__sub">
            We're here to answer your questions, discuss your project, and
            provide the strategic support your business needs. Reach out and our
            team will get back to you promptly.
          </p>
        </div>

        <div class="ws-contact__body">
          <!-- Left -->
          <div class="ws-contact__left">
            <!-- Blue visual card -->
            <div class="ws-contact__visual">
              <div class="ws-bubbles">
                <img src="assets/images/CTA ENGLISH.png" role="img" aria-label="Abstract blue bubbles" alt="Abstract blue bubbles" />
              </div>
            </div>

            <!-- Info cards -->
            <div class="ws-contact__info">
              <div class="ws-info-card">
                <div class="ws-info-card__icon">
                  <i class="fas fa-envelope"></i>
                </div>
                <div>
                  <h6 class="ws-info-card__title">Email</h6>
                  <p class="ws-info-card__val">contact@wusul.tech</p>
                </div>
              </div>

              <div class="ws-info-card">
                <div class="ws-info-card__icon">
                  <i class="fas fa-phone"></i>
                </div>
                <div>
                  <h6 class="ws-info-card__title">Phone</h6>
                  <p class="ws-info-card__val">+970 123 456 789</p>
                </div>
              </div>

              <div class="ws-info-card">
                <div class="ws-info-card__icon">
                  <i class="fas fa-map-location-dot"></i>
                </div>
                <div>
                  <h6 class="ws-info-card__title">Address</h6>
                  <p class="ws-info-card__val">
                    Palestine Street, Gaza, Palestine
                  </p>
                </div>
              </div>

              <div class="ws-info-card">
                <div class="ws-info-card__icon">
                  <i class="fas fa-clock"></i>
                </div>
                <div>
                  <h6 class="ws-info-card__title">Working Hours</h6>
                  <p class="ws-info-card__val">Sun – Thu | 9:00 AM – 5:00 PM</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right — Form -->
          <div class="ws-contact__right">
            <h4 class="ws-form__title">
              Share your idea and we'll get back to you…
            </h4>
            <p class="ws-form__sub">
              Do you have an idea or inquiry? Fill in your details and we'll get
              back to you within 24 hours.
            </p>

            <div class="ws-form">
              <div class="ws-field">
                <label class="ws-field__label">Full Name <span>*</span></label>
                <input
                  type="text"
                  class="ws-field__input"
                  placeholder="Example: Yousef Samy"
                />
              </div>

              <div class="ws-field">
                <label class="ws-field__label"
                  >Email Address <span>*</span></label
                >
                <input
                  type="email"
                  class="ws-field__input"
                  placeholder="Example: example@email.com"
                />
              </div>

              <div class="ws-field">
                <label class="ws-field__label"
                  >Phone Number <span>*</span></label
                >
                <input
                  type="tel"
                  class="ws-field__input"
                  placeholder="Example: +970 59-770-5019"
                />
              </div>

              <div class="ws-field">
                <label class="ws-field__label"
                  >Project Type <span>*</span></label
                >
                <input
                  type="text"
                  class="ws-field__input"
                  placeholder="Example: E-commerce, Dash or SaaS Redesign"
                />
              </div>

              <div class="ws-field">
                <label class="ws-field__label">Message <span>*</span></label>
                <textarea
                  class="ws-field__input ws-field__textarea"
                  placeholder="Example: I have a great idea for an app or website and need expert consultation on UI/UX design and development to bring this idea to life."
                ></textarea>
              </div>

              <button type="submit" class="ws-form__btn">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M4.5 16.5c-1.5 1.26-2.5 3.19-2.5 5.5h20c0-2.31-1-4.24-2.5-5.5"
                  />
                  <path
                    d="M12 2C7.5 2 4 4.5 4 8.5c0 .76.1 1.48.3 2.15L8 16h8l3.7-5.35c.2-.67.3-1.39.3-2.15C20 4.5 16.5 2 12 2z"
                  />
                </svg>
                Send The Idea
              </button>
            </div>
          </div>
        </div>

        <div class="ws-contact__map">
          <img src="assets/images/map.svg" role="img" aria-label="World map with contact pin" alt="World map with contact pin" />
        </div>
      </div>
    </section>
